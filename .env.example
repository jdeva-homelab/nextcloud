# Nextcloud Environment Configuration
TZ=Europe/Dublin

# Database
DB_USER=nextcloud
DB_PASSWORD=your-secure-password
DB_NAME=nextcloud

# Nextcloud Admin
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=your-secure-password

# Data locations
NEXTCLOUD_DATA_LOCATION=/mnt/nas/cloud/nextcloud/data
DB_DATA_LOCATION=/home/jdev/Documents/docker/volumes/nextcloud/postgres
NEXTCLOUD_APP_LOCATION=/home/jdev/Documents/docker/volumes/nextcloud/app

# SMTP Configuration
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_AUTHTYPE=LOGIN
SMTP_USER=user@example.com
SMTP_PASS=secure-password
MAIL_FROM_ADDRESS=cloud
MAIL_DOMAIN=example.com
